# ================================================
# CONFIGURACIÓN DE SEGURIDAD - Vue-Chat Backend
# ================================================
# Copia este archivo a .env y completa los valores

# ================================================
# SERVIDOR
# ================================================
FLASK_ENV=development
FLASK_DEBUG=True
SERVER_HOST=127.0.0.1
SERVER_PORT=5000

# ================================================
# AUTENTICACIÓN JWT
# ================================================
JWT_SECRET_KEY=tu-secret-key-aqui-cambia-en-produccion
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 horas

# ================================================
# OPENAI (ChatGPT)
# ================================================
OPENAI_API_KEY=sk-tu-api-key-aqui

# ================================================
# OLLAMA (Modelos Locales)
# ================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ================================================
# CORS - Lista de orígenes permitidos
# ================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173

# ================================================
# RATE LIMITING
# ================================================
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200

# ================================================
# SEGURIDAD ADICIONAL
# ================================================
MAX_CONTENT_LENGTH=10000  # Máx caracteres por mensaje